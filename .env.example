# ============================================================
# Orbit — Environment Variables
# ============================================================

# Database (PostgreSQL — required)
DATABASE_URL="postgresql://user:password@host:5432/dropai"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI (existing AI services)
OPENAI_API_KEY="sk-..."

# ── Data Pipeline ───────────────────────────────────────────

# SerpAPI — Google Shopping & Trends data
# Free tier: 100 searches/month — https://serpapi.com/
SERPAPI_KEY=""
SERPAPI_API_KEY=""

# Google Gemini — AI trend analysis & product scoring
# Free tier: 15 RPM, 1M TPM — https://aistudio.google.com/apikey
GOOGLE_API_KEY=""
GEMINI_API_KEY=""

# Cron Job Secret — protects /api/cron/daily-refresh
# Generate: openssl rand -hex 32
CRON_SECRET=""

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
